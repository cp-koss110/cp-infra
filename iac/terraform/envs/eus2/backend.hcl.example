# Terraform Backend Configuration for S3 + DynamoDB
# Copy this file to backend.hcl and fill in your values
# cp backend.hcl.example backend.hcl

# Run: terraform init -backend-config=backend.hcl

# S3 bucket for Terraform state
bucket = "exam-costa-terraform-state"

# Key path for this environment's state file
key = "envs/eus2/terraform.tfstate"

# AWS region where the bucket is located
region = "us-east-2"

# DynamoDB table for state locking
dynamodb_table = "exam-costa-terraform-locks"

# Enable encryption at rest
encrypt = true

# Optional: S3 bucket key for SSE-KMS encryption
# kms_key_id = "arn:aws:kms:us-east-2:ACCOUNT_ID:key/KEY_ID"

# Optional: Role ARN for assuming cross-account access
# role_arn = "arn:aws:iam::ACCOUNT_ID:role/TerraformBackendRole"

# ==========================================
# Prerequisites:
# ==========================================
# 1. Create S3 bucket:
#    aws s3api create-bucket \
#      --bucket exam-costa-terraform-state \
#      --region us-east-2 \
#      --create-bucket-configuration LocationConstraint=us-east-2
#
# 2. Enable versioning:
#    aws s3api put-bucket-versioning \
#      --bucket exam-costa-terraform-state \
#      --versioning-configuration Status=Enabled
#
# 3. Enable encryption:
#    aws s3api put-bucket-encryption \
#      --bucket exam-costa-terraform-state \
#      --server-side-encryption-configuration \
#      '{"Rules":[{"ApplyServerSideEncryptionByDefault":{"SSEAlgorithm":"AES256"}}]}'
#
# 4. Create DynamoDB table:
#    aws dynamodb create-table \
#      --table-name exam-costa-terraform-locks \
#      --attribute-definitions AttributeName=LockID,AttributeType=S \
#      --key-schema AttributeName=LockID,KeyType=HASH \
#      --billing-mode PAY_PER_REQUEST \
#      --region us-east-2
#
# 5. Block public access:
#    aws s3api put-public-access-block \
#      --bucket exam-costa-terraform-state \
#      --public-access-block-configuration \
#      "BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true"
